---
interface Props {
  pdfUrl: string;
  title?: string;
}

const { pdfUrl, title = "PDF 閱讀" } = Astro.props;

// 使用 Google Docs Viewer 來顯示 PDF
const viewerUrl = `https://docs.google.com/gview?embedded=1&url=${pdfUrl}`;
---

<div class="pdf-viewer-wrapper">
  <div class="viewer-header">
    <h3>{title}</h3>
    <a href={pdfUrl} target="_blank" class="download-btn">下載 PDF</a>
  </div>
  
  <div class="iframe-container">
    <iframe 
      src={viewerUrl}
      title={title}
      frameborder="0"
      allowfullscreen
    ></iframe>
  </div>
</div>

<style>
  .pdf-viewer-wrapper {
    background: white;
    border-radius: 10px;
    overflow: hidden;
    box-shadow: 0 10px 40px rgba(0,0,0,0.2);
    margin: 2rem auto;
    max-width: 800px;
  }

  .viewer-header {
    background: linear-gradient(135deg, #8B4513, #228B22);
    color: white;
    padding: 1rem;
    display: flex;
    justify-content: space-between;
    align-items: center;
    flex-wrap: wrap;
    gap: 0.5rem;
  }

  .viewer-header h3 { margin: 0; font-size: 1.1rem; }

  .download-btn {
    background: rgba(255,255,255,0.25);
    color: white;
    padding: 0.5rem 1rem;
    border-radius: 5px;
    text-decoration: none;
    font-size: 0.9rem;
    transition: all 0.3s ease;
  }

  .download-btn:hover {
    background: rgba(255,255,255,0.4);
  }

  .iframe-container {
    width: 100%;
    height: 80vh;
    min-height: 500px;
    background: #f5f5f5;
  }

  .iframe-container iframe {
    width: 100%;
    height: 100%;
  }

  @media (max-width: 768px) {
    .viewer-header {
      flex-direction: column;
      text-align: center;
    }
    .iframe-container {
      height: 60vh;
      min-height: 400px;
    }
  }
</style>