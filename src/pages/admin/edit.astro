---
// 管理後台 - 所見即所得編輯器
import Layout from '../../layouts/Layout.astro';
---

<Layout title="編輯頁面 | 光禾華德福">
  
  <div class="editor-layout">
    <!-- 工具欄 -->
    <header class="editor-toolbar">
      <div class="toolbar-left">
        <a href="/admin" class="back-btn">← 後台</a>
        <span class="page-title" id="pageTitle">載入中...</span>
      </div>
      <div class="toolbar-right">
        <button class="btn btn-secondary" onclick="addElement('h2')">➕ 標題</button>
        <button class="btn btn-secondary" onclick="addElement('p')">➕ 段落</button>
        <button class="btn btn-secondary" onclick="addElement('ul')">➕ 列表</button>
        <button class="btn btn-secondary" onclick="addElement('table')">➕ 表格</button>
        <button class="btn btn-save" onclick="savePage()">💾 儲存變更</button>
      </div>
    </header>

    <!-- 編輯區域 -->
    <div class="editor-container">
      <div class="editor-wrapper" id="editorArea" contenteditable="true">
      </div>
    </div>

    <!-- 儲存成功提示 -->
    <div class="toast" id="toast">✅ 儲存成功！</div>
  </div>

  <script>
    let pagesData = {};
    let pageKey = 'home';

    // 載入資料
    async function loadPages() {
      try {
        const response = await fetch('/data/pages.json');
        pagesData = await response.json();
        
        const urlParams = new URLSearchParams(window.location.search);
        pageKey = urlParams.get('page') || 'home';
        const currentPage = pagesData[pageKey] || { title: '未找到', content: '<p>請選擇頁面</p>' };

        document.getElementById('pageTitle').textContent = '✏️ ' + currentPage.title;
        document.getElementById('editorArea').innerHTML = currentPage.content || '';
      } catch (error) {
        console.error('載入失敗:', error);
        document.getElementById('pageTitle').textContent = '✏️ 載入失敗';
      }
    }

    // 新增元素
    function addElement(type) {
      const editor = document.getElementById('editorArea');
      let newEl = '';
      
      switch(type) {
        case 'h2':
          newEl = '<h2>新標題</h2>';
          break;
        case 'p':
          newEl = '<p>新段落內容...</p>';
          break;
        case 'ul':
          newEl = '<ul><li>項目一</li><li>項目二</li><li>項目三</li></ul>';
          break;
        case 'table':
          newEl = '<table border="1" cellpadding="8"><tr><th>標題</th><th>內容</th></tr><tr><td>項目一</td><td>說明</td></tr></table>';
          break;
      }
      
      editor.focus();
      document.execCommand('insertHTML', false, newEl);
    }

    // 儲存到伺服器
    async function savePage() {
      const content = document.getElementById('editorArea').innerHTML;
      const title = document.getElementById('pageTitle').textContent.replace('✏️ ', '');
      
      pagesData[pageKey] = { title, content };
      
      try {
        // 使用 Fetch API 下載 JSON 檔案（讓 Ming 可以複製）
        const jsonStr = JSON.stringify(pagesData, null, 2);
        const blob = new Blob([jsonStr], { type: 'application/json' });
        const url = URL.createObjectURL(blob);
        
        const a = document.createElement('a');
        a.href = url;
        a.download = 'pages.json';
        a.click();
        URL.revokeObjectURL(url);
        
        const toast = document.getElementById('toast');
        toast.textContent = '✅ 已下載最新資料檔！請將 pages.json 覆蓋到 public/data/ 資料夾';
        toast.classList.add('show');
        setTimeout(() => toast.classList.remove('show'), 4000);
      } catch (error) {
        console.error('儲存失敗:', error);
        alert('儲存失敗，請重試');
      }
    }

    // 初始化
    loadPages();

    // 離開時提示未儲存
    window.onbeforeunload = function() {
      return '您有未儲存的變更，確定要離開嗎？';
    };
  </script>

</Layout>

<style is:global>
  * { margin: 0; padding: 0; box-sizing: border-box; }
  body { font-family: 'Noto Sans TC', -apple-system, sans-serif; background: #f5f5f5; }
</style>

<style>
  .editor-layout { min-height: 100vh; background: #f5f5f5; }
  .editor-toolbar { background: white; padding: 1rem 1.5rem; display: flex; justify-content: space-between; align-items: center; box-shadow: 0 2px 15px rgba(0,0,0,0.1); position: sticky; top: 0; z-index: 100; flex-wrap: wrap; gap: 1rem; }
  .toolbar-left { display: flex; align-items: center; gap: 1rem; }
  .back-btn { color: #666; text-decoration: none; padding: 0.5rem 1rem; border-radius: 8px; background: #f0f0f0; font-size: 0.9rem; }
  .back-btn:hover { background: #e0e0e0; }
  .page-title { font-size: 1.1rem; color: #333; font-weight: bold; }
  .toolbar-right { display: flex; gap: 0.5rem; flex-wrap: wrap; }
  .btn { padding: 0.6rem 1rem; border: none; border-radius: 8px; cursor: pointer; font-size: 0.85rem; transition: all 0.2s; font-family: inherit; }
  .btn:hover { transform: scale(1.05); }
  .btn-secondary { background: #e8f5e9; color: #2e7d32; }
  .btn-secondary:hover { background: #c8e6c9; }
  .btn-save { background: linear-gradient(135deg, #228B22, #8B4513); color: white; font-weight: bold; }
  .editor-container { padding: 2rem; max-width: 1100px; margin: 0 auto; }
  .editor-wrapper { background: white; padding: 3rem; border-radius: 20px; box-shadow: 0 5px 30px rgba(0,0,0,0.1); min-height: 500px; line-height: 1.8; outline: none; }
  .editor-wrapper:focus { box-shadow: 0 5px 30px rgba(34,139,34,0.2); }
  .editor-wrapper h1, .editor-wrapper h2 { color: #8B4513; margin: 1.5rem 0 1rem; }
  .editor-wrapper h3 { color: #228B22; margin: 1.2rem 0 0.8rem; }
  .editor-wrapper p { color: #555; margin-bottom: 1rem; }
  .editor-wrapper ul, .editor-wrapper ol { padding-left: 1.5rem; margin-bottom: 1rem; }
  .editor-wrapper li { color: #555; padding: 0.3rem 0; }
  .editor-wrapper table { width: 100%; border-collapse: collapse; margin: 1rem 0; }
  .editor-wrapper td, .editor-wrapper th { padding: 0.8rem; border: 1px solid #ddd; }
  .editor-wrapper th { background: #f5f5f5; color: #8B4513; }
  .toast { position: fixed; bottom: 2rem; right: 2rem; background: #228B22; color: white; padding: 1rem 2rem; border-radius: 10px; opacity: 0; transition: opacity 0.3s; font-weight: bold; }
  .toast.show { opacity: 1; }
</style>
