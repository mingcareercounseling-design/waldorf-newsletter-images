---
import Layout from '../../layouts/Layout.astro';
import Navigation from '../../components/Navigation.astro';
---

<Layout title="教學正常化 | 光禾華德福">
  <Navigation />
  
  <section class="hero-small">
    <div class="container">
      <h1>教學正常化</h1>
      <p>教學正常化自我檢核與課表</p>
    </div>
  </section>

  <section class="section">
    <div class="container">
      
      <div class="content-block">
        <h2>114學年度</h2>
        <ul>
          <li>114學年度國民中學正常教學學校自我檢核表</li>
          <li>114-1晤談紀錄表</li>
          <li>114-七年級課表-秋冬學季</li>
          <li>114-八年級課表-秋冬學季</li>
          <li>114-九年級課表-秋冬學季</li>
        </ul>
      </div>

      <div class="content-block">
        <h2>113學年度課表</h2>
        <ul>
          <li>113學年度 七年級課表</li>
          <li>113學年度 八年級課表</li>
          <li>113學年度 九年級課表</li>
          <li>113學年國民中學教學正常化自我檢核表</li>
          <li>113學年度晤談紀錄表</li>
        </ul>
      </div>

      <div class="content-block">
        <h2>112學年度 G7-G9課表</h2>
        <ul>
          <li>112學年度 七年級課表</li>
          <li>112學年度 八年級課表</li>
          <li>112學年度 九年級課表</li>
          <li>112學年國民中學教學正常化自我檢核表</li>
        </ul>
      </div>

      <div class="content-block">
        <h2>主課程說明</h2>
        <p>華德福的主課程是一個週期性狀態，透過這個歷程讓學生專注且持續約三至四週的學習，課程領域包含：文史，自然、數學等。在學習歷程中學生透過課程藝術化的引導吸收所學的「知識」，並透過充分的睡眠，經由隔天在課堂上的「回顧與重述」，讓經驗轉化成自己的能力，並書寫在自己的工作本上。</p>
      </div>

      <div class="content-block">
        <h2>109-111學年度 課程圖像</h2>
        <ul>
          <li>七年級 天使班 衛教活動及課程</li>
          <li>八年級 水晶班 學習樣貌</li>
          <li>七年級 榕樹班 自行車募款</li>
          <li>八年級 天使班 獨木舟活動</li>
          <li>九年級 水晶班 學習樣貌</li>
          <li>七年級 芙蓉班 英文戲劇</li>
          <li>八年級 榕樹班 茶道</li>
          <li>九年級 天使班 畢業公演</li>
          <li>十年級 水晶班 自行車旅行</li>
        </ul>
      </div>

      <div class="content-block">
        <h2>107-108學年度 課程圖像</h2>
        <ul>
          <li>七年級 簡單機械</li>
          <li>八年級 流體力學</li>
          <li>七年級 生理學</li>
        </ul>
      </div>

    </div>
  </section>

  <footer class="footer">
    <div class="container">
      <p>© 2026 光禾華德福實驗學校. All rights reserved.</p>
    </div>
  </footer>
</Layout>

<style>
  .hero-small {
    background: linear-gradient(135deg, #8B4513, #228B22);
    color: white;
    padding: 4rem 2rem;
    text-align: center;
  }

  .hero-small h1 { font-size: 3rem; margin-bottom: 0.5rem; }
  .hero-small p { font-size: 1.2rem; opacity: 0.9; }

  .section { padding: 4rem 2rem; }
  .container { max-width: 800px; margin: 0 auto; }

  .content-block {
    background: white;
    padding: 2rem;
    border-radius: 20px;
    margin-bottom: 1.5rem;
    box-shadow: 0 10px 40px rgba(139,69,19,0.1);
  }

  .content-block h2 {
    color: #8B4513;
    font-size: 1.3rem;
    margin-bottom: 1rem;
  }

  .content-block p {
    color: #666;
    line-height: 1.8;
  }

  .content-block ul {
    padding-left: 1.5rem;
    color: #666;
  }

  .content-block li {
    padding: 0.3rem 0;
  }

  .footer { background: #333; color: white; padding: 2rem; text-align: center; margin-top: 2rem; }
</style>
