---
interface Props {
  imageUrls: string[];
  title?: string;
}

const { imageUrls, title = "電子書" } = Astro.props;
---

<div class="flipbook-wrapper">
  <div class="flipbook-header">
    <h3>{title}</h3>
    <div class="flipbook-controls">
      <button id="prev-btn" class="ctrl-btn">◀</button>
      <span id="page-info">
        <span id="current-page">1</span> / <span id="total-pages">{imageUrls.length}</span>
      </span>
      <button id="next-btn" class="ctrl-btn">▶</button>
      <button id="fullscreen-btn" class="ctrl-btn">⛶</button>
    </div>
  </div>
  
  <div class="flipbook-viewport" id="flipbook-viewport">
    <div class="pages" id="pages">
      {imageUrls.map((url, idx) => (
        <div class="page" data-index={idx}>
          <img src={url} alt={`Page ${idx + 1}`} loading={idx < 2 ? "eager" : "lazy"} />
        </div>
      ))}
    </div>
  </div>
</div>

<script is:inline>
(function() {
  const pages = document.querySelectorAll('.page');
  const pagesContainer = document.getElementById('pages');
  const totalPages = pages.length;
  let currentPage = 0;

  function updateDisplay() {
    // Slide effect - move container
    pagesContainer.style.transform = `translateX(-${currentPage * 100}%)`;
    
    document.getElementById('current-page').textContent = (currentPage + 1).toString();
    document.getElementById('prev-btn').disabled = currentPage <= 0;
    document.getElementById('next-btn').disabled = currentPage >= totalPages - 1;
  }

  function nextPage() {
    if (currentPage < totalPages - 1) {
      currentPage++;
      updateDisplay();
    }
  }

  function prevPage() {
    if (currentPage > 0) {
      currentPage--;
      updateDisplay();
    }
  }

  function goToPage(index) {
    if (index >= 0 && index < totalPages) {
      currentPage = index;
      updateDisplay();
    }
  }

  // Fullscreen
  document.getElementById('fullscreen-btn').addEventListener('click', function() {
    const viewport = document.getElementById('flipbook-viewport');
    if (document.fullscreenElement) {
      document.exitFullscreen();
    } else {
      viewport.requestFullscreen();
    }
  });

  // Button events
  document.getElementById('next-btn').addEventListener('click', nextPage);
  document.getElementById('prev-btn').addEventListener('click', prevPage);

  // Keyboard
  document.addEventListener('keydown', (e) => {
    if (e.key === 'ArrowRight') nextPage();
    if (e.key === 'ArrowLeft') prevPage();
    if (e.key === 'f' || e.key === 'F') {
      document.getElementById('fullscreen-btn').click();
    }
  });

  // Touch swipe
  let touchStartX = 0;
  document.getElementById('flipbook-viewport').addEventListener('touchstart', (e) => {
    touchStartX = e.touches[0].clientX;
  }, { passive: true });
  
  document.getElementById('flipbook-viewport').addEventListener('touchend', (e) => {
    const diff = touchStartX - e.changedTouches[0].clientX;
    if (Math.abs(diff) > 50) {
      if (diff > 0) nextPage();
      else prevPage();
    }
  }, { passive: true });

  // Mouse drag
  let isDragging = false;
  let dragStartX = 0;
  
  document.getElementById('flipbook-viewport').addEventListener('mousedown', (e) => {
    isDragging = true;
    dragStartX = e.clientX;
  });
  
  document.getElementById('flipbook-viewport').addEventListener('mousemove', (e) => {
    if (!isDragging) return;
    const diff = dragStartX - e.clientX;
    if (Math.abs(diff) > 30) {
      if (diff > 0) nextPage();
      else prevPage();
      isDragging = false;
    }
  });
  
  document.getElementById('flipbook-viewport').addEventListener('mouseup', () => {
    isDragging = false;
  });

  // Initialize
  updateDisplay();
})();
</script>

<style>
  .flipbook-wrapper {
    max-width: 100%;
    margin: 0 auto;
    background: linear-gradient(180deg, #3d2817 0%, #1a0f0a 30%, #1a0f0a 70%, #3d2817 100%);
    border-radius: 12px;
    padding: 15px;
    box-shadow: 0 20px 60px rgba(0,0,0,0.6);
  }

  .flipbook-header {
    background: linear-gradient(135deg, #8B4513, #228B22);
    color: white;
    padding: 10px 15px;
    border-radius: 8px 8px 0 0;
    display: flex;
    justify-content: space-between;
    align-items: center;
    flex-wrap: wrap;
    gap: 10px;
  }

  .flipbook-header h3 {
    margin: 0;
    font-size: 1rem;
    word-break: break-word;
  }

  .flipbook-controls {
    display: flex;
    align-items: center;
    gap: 8px;
    flex-wrap: wrap;
  }

  .ctrl-btn {
    background: rgba(255,255,255,0.2);
    border: none;
    color: white;
    padding: 8px 12px;
    border-radius: 4px;
    cursor: pointer;
    font-size: 1rem;
    transition: background 0.2s;
  }

  .ctrl-btn:hover { background: rgba(255,255,255,0.3); }
  .ctrl-btn:disabled { opacity: 0.4; cursor: not-allowed; }

  #page-info {
    font-weight: bold;
    font-size: 0.9rem;
    min-width: 60px;
    text-align: center;
  }

  .flipbook-viewport {
    width: 100%;
    overflow: hidden;
    background: #1a0f0a;
    border-radius: 4px;
    position: relative;
    cursor: grab;
  }

  .flipbook-viewport:active {
    cursor: grabbing;
  }

  .pages {
    display: flex;
    transition: transform 0.4s ease;
    width: 100%;
  }

  .page {
    min-width: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 10px;
    box-sizing: border-box;
  }

  .page img {
    max-width: 100%;
    max-height: 75vh;
    object-fit: contain;
    display: block;
    box-shadow: 0 4px 20px rgba(0,0,0,0.4);
    border-radius: 4px;
    background: white;
  }

  /* Fullscreen styles */
  :fullscreen .flipbook-wrapper {
    max-width: 100vw;
    height: 100vh;
    border-radius: 0;
    display: flex;
    flex-direction: column;
    padding: 0;
  }

  :fullscreen .flipbook-header {
    flex-shrink: 0;
    border-radius: 0;
  }

  :fullscreen .flipbook-viewport {
    flex: 1;
    display: flex;
    align-items: center;
    justify-content: center;
    background: #000;
  }

  :fullscreen .page {
    padding: 20px;
  }

  :fullscreen .page img {
    max-height: calc(100vh - 80px);
    max-width: 100%;
  }

  @media (max-width: 600px) {
    .flipbook-wrapper {
      padding: 8px;
      border-radius: 8px;
    }
    .flipbook-header {
      flex-direction: column;
      text-align: center;
      padding: 8px;
    }
    .flipbook-header h3 {
      font-size: 0.9rem;
    }
    .ctrl-btn {
      padding: 6px 10px;
      font-size: 0.9rem;
    }
    #page-info {
      font-size: 0.8rem;
    }
    .page img {
      max-height: 60vh;
    }
  }
</style>
