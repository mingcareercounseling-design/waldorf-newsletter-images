<style>
  .hero-small {
    background: linear-gradient(135deg, #8B4513, #228B22);
    color: white;
    padding: 4rem 2rem;
    text-align: center;
  }

  .hero-small h1 { font-size: 3rem; margin-bottom: 0.5rem; }
  .hero-small p { font-size: 1.2rem; opacity: 0.9; }

  .section { padding: 4rem 2rem; }
  .container { max-width: 1000px; margin: 0 auto; }

  .content-block {
    background: white;
    padding: 2rem;
    border-radius: 20px;
    margin-bottom: 2rem;
    box-shadow: 0 10px 40px rgba(139,69,19,0.1);
  }

  .content-block h2 {
    color: #8B4513;
    font-size: 1.5rem;
    margin-bottom: 1rem;
    border-bottom: 2px solid #FFD700;
    padding-bottom: 0.5rem;
  }

  .content-block p {
    color: #666;
    line-height: 1.8;
  }

  .grade-section {
    margin: 2rem 0;
  }

  .grade-section h3 {
    color: #228B22;
    font-size: 1.3rem;
    margin-bottom: 1rem;
    padding-bottom: 0.5rem;
    border-bottom: 1px solid #e0e0e0;
  }

  .video-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.5rem;
    margin-top: 1rem;
  }

  @media (max-width: 900px) {
    .video-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 600px) {
    .video-grid {
      grid-template-columns: 1fr;
    }
  }

  .video-item {
    background: #f9f9f9;
    border-radius: 15px;
    overflow: hidden;
    box-shadow: 0 4px 15px rgba(0,0,0,0.1);
  }

  .video-container {
    position: relative;
    padding-bottom: 56.25%;
    height: 0;
    overflow: hidden;
  }

  .video-container iframe {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
  }

  .video-item p {
    padding: 1rem;
    margin: 0;
    font-size: 0.95rem;
    color: #555;
    text-align: center;
  }

  .footer { background: #333; color: white; padding: 2rem; text-align: center; margin-top: 2rem; }
</style>
