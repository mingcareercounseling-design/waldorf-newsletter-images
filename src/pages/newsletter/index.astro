---
import Layout from '../../layouts/Layout.astro';
import Navigation from '../../components/Navigation.astro';

// 所有期數（含封面圖路徑）
const issues = [
  { id: '36', title: '第36期', semester: '113學年度 秋冬學季合輯', cover: '/newsletter/光禾通訊/NO36-01.png' },
  { id: '35', title: '第35期', semester: '112學年度 秋冬學季合輯', cover: '/newsletter/光禾通訊/NO35-001.png' },
  { id: '34', title: '第34期', semester: '112學年度 冬春夏學季合輯', cover: '/newsletter/光禾通訊/NO34-001.png' },
  { id: '33', title: '第33期', semester: '112學年度 春學季刊', cover: '/newsletter/光禾通訊/NO33-01.jpg' },
  { id: '32', title: '第32期', semester: '112學年度 夏學季刊', cover: '/newsletter/光禾通訊/NO32-01.jpg' },
  { id: '31', title: '第31期', semester: '111學年度 春學季刊', cover: '/newsletter/光禾通訊/NO31-01.jpg' },
  { id: '30', title: '第30期', semester: '110學年度 冬學季刊', cover: '/newsletter/光禾通訊/NO30-01.jpg' },
  { id: '29', title: '第29期', semester: '110學年度 秋學季刊', cover: '/newsletter/光禾通訊/NO29-01.jpg' },
  { id: '28', title: '第28期', semester: '110學年度 夏學季刊', cover: '/newsletter/光禾通訊/NO28-01.jpg' },
  { id: '27', title: '第27期', semester: '110學年度 春學季刊', cover: '/newsletter/光禾通訊/NO27-01.jpg' },
  { id: '26', title: '第26期', semester: '109學年度 夏學季刊', cover: '/newsletter/光禾通訊/NO26-01.jpg' },
  { id: '24-25', title: '第24-25期', semester: '113-114學年度合訂本', cover: '/newsletter/光禾通訊/NO24-25-01.jpg' },
  { id: '23', title: '第23期', semester: '109學年度 春學季刊', cover: '/newsletter/光禾通訊/NO23-01.jpg' },
];

const latest = issues[0];
const rest = issues.slice(1);
---

<Layout title="光禾通訊">
  <Navigation />

  <section class="hero">
    <div class="container">
      <h1>📰 光禾通訊</h1>
      <p>光禾華德福實驗學校每學季發行的校園通訊，記錄光禾的點點滴滴</p>
    </div>
  </section>

  <section class="section">
    <div class="container">

      <!-- 最新一期：大卡片 -->
      <div class="latest-card">
        <a href={`/newsletter/${latest.id}`} class="latest-cover-link">
          <img src={latest.cover} alt={latest.title} class="latest-cover" loading="eager" />
          <div class="latest-badge">最新一期</div>
        </a>
        <div class="latest-info">
          <h2>{latest.title}</h2>
          <p class="semester">{latest.semester}</p>
          <a href={`/newsletter/${latest.id}`} class="read-btn">📖 立即翻閱</a>
        </div>
      </div>

      <!-- 其他期數：格狀封面 -->
      <h3 class="section-title">📚 過往期數</h3>
      <div class="issues-grid">
        {rest.map(issue => (
          <a href={`/newsletter/${issue.id}`} class="issue-card">
            <div class="cover-wrap">
              <img src={issue.cover} alt={issue.title} class="issue-cover" loading="lazy" />
              <div class="cover-overlay">
                <span>📖 開始閱讀</span>
              </div>
            </div>
            <div class="issue-info">
              <h4>{issue.title}</h4>
              <p>{issue.semester}</p>
            </div>
          </a>
        ))}
      </div>

    </div>
  </section>
</Layout>

<style>
  .hero {
    background: linear-gradient(135deg, #8B4513, #228B22);
    color: white;
    padding: 4rem 2rem;
    text-align: center;
  }
  .hero h1 { font-size: 2.5rem; margin-bottom: 0.5rem; }
  .hero p  { font-size: 1.1rem; opacity: 0.9; }

  .section  { padding: 3rem 2rem; }
  .container { max-width: 1000px; margin: 0 auto; }

  /* ── 最新一期 ── */
  .latest-card {
    display: flex;
    gap: 2rem;
    align-items: flex-start;
    background: white;
    border-radius: 20px;
    padding: 2rem;
    box-shadow: 0 12px 40px rgba(0,0,0,0.12);
    margin-bottom: 3rem;
  }
  .latest-cover-link {
    position: relative;
    flex-shrink: 0;
    display: block;
    width: 200px;
  }
  .latest-cover {
    width: 100%;
    border-radius: 10px;
    box-shadow: 4px 4px 20px rgba(0,0,0,0.25);
    display: block;
  }
  .latest-badge {
    position: absolute;
    top: -10px; left: -10px;
    background: linear-gradient(135deg, #e74c3c, #c0392b);
    color: white;
    font-size: 0.75rem;
    font-weight: 700;
    padding: 4px 10px;
    border-radius: 20px;
    box-shadow: 0 2px 8px rgba(0,0,0,0.2);
  }
  .latest-info {
    flex: 1;
    padding-top: 0.5rem;
  }
  .latest-info h2 {
    font-size: 1.8rem;
    color: #8B4513;
    margin-bottom: 0.5rem;
  }
  .latest-info .semester {
    color: #666;
    font-size: 1rem;
    margin-bottom: 1.5rem;
  }
  .read-btn {
    display: inline-block;
    background: linear-gradient(135deg, #8B4513, #228B22);
    color: white;
    padding: 0.8rem 2rem;
    border-radius: 30px;
    text-decoration: none;
    font-size: 1.05rem;
    font-weight: 600;
    transition: transform 0.2s, box-shadow 0.2s;
    box-shadow: 0 4px 15px rgba(139,69,19,0.35);
  }
  .read-btn:hover { transform: scale(1.05); box-shadow: 0 6px 20px rgba(139,69,19,0.45); }

  /* ── 過往期數標題 ── */
  .section-title {
    font-size: 1.3rem;
    color: #8B4513;
    margin-bottom: 1.2rem;
    padding-bottom: 0.5rem;
    border-bottom: 2px solid #e8d5c0;
  }

  /* ── 格狀列表 ── */
  .issues-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(150px, 1fr));
    gap: 1.2rem;
  }
  .issue-card {
    text-decoration: none;
    color: inherit;
    background: white;
    border-radius: 12px;
    overflow: hidden;
    box-shadow: 0 4px 15px rgba(0,0,0,0.1);
    transition: transform 0.25s, box-shadow 0.25s;
  }
  .issue-card:hover {
    transform: translateY(-5px);
    box-shadow: 0 10px 30px rgba(0,0,0,0.18);
  }
  .cover-wrap {
    position: relative;
    overflow: hidden;
    aspect-ratio: 3/4;
    background: #f0ebe5;
  }
  .issue-cover {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 0.3s;
  }
  .issue-card:hover .issue-cover { transform: scale(1.05); }
  .cover-overlay {
    position: absolute;
    inset: 0;
    background: rgba(139,69,19,0.7);
    color: white;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 0.9rem;
    font-weight: 600;
    opacity: 0;
    transition: opacity 0.25s;
  }
  .issue-card:hover .cover-overlay { opacity: 1; }
  .issue-info {
    padding: 0.6rem 0.7rem;
  }
  .issue-info h4 {
    font-size: 0.9rem;
    color: #8B4513;
    margin: 0 0 0.2rem;
    font-weight: 700;
  }
  .issue-info p {
    font-size: 0.75rem;
    color: #888;
    margin: 0;
    line-height: 1.3;
  }

  /* ── 手機 ── */
  @media (max-width: 600px) {
    .latest-card { flex-direction: column; align-items: center; text-align: center; }
    .latest-cover-link { width: 160px; }
    .issues-grid { grid-template-columns: repeat(auto-fill, minmax(120px, 1fr)); gap: 0.8rem; }
  }
</style>
