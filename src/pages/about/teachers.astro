---
import Layout from '../../layouts/Layout.astro';
import Navigation from '../../components/Navigation.astro';
---

<Layout title="教職團隊 | 光禾華德福">
  <Navigation />
  
  <section class="hero-small">
    <div class="container">
      <h1>教職團隊</h1>
      <p>專業且充滿愛心的教師團隊</p>
    </div>
  </section>

  <section class="section">
    <div class="container">
      
      <!-- 教學核心小組 -->
      <div class="team-section">
        <h2>教學核心小組</h2>
        <div class="core-team">
          <div class="team-card">
            <img src="/images/teachers/teacher3.png" alt="許慧玲" class="teacher-photo"/>
            <h3>校長</h3>
            <p class="name">許慧玲</p>
          </div>
          <div class="team-card">
            <img src="/images/teachers/teacher4.png" alt="林季瑩" class="teacher-photo"/>
            <h3>小學部教師會主席</h3>
            <p class="name">林季瑩</p>
          </div>
          <div class="team-card">
            <img src="/images/teachers/teacher5.png" alt="葉友竹" class="teacher-photo"/>
            <h3>中學部教師會主席</h3>
            <p class="name">葉友竹</p>
          </div>
        </div>
      </div>

      <!-- 行政團隊 -->
      <div class="team-section">
        <h2>行政團隊</h2>
        <div class="admin-grid">
          <div class="team-card small">
            <h3>學務</h3>
            <p class="name">潘韻如</p>
          </div>
          <div class="team-card small">
            <h3>總務</h3>
            <p class="name">侯慕龍</p>
          </div>
          <div class="team-card small">
            <h3>教務</h3>
            <p class="name">姜宜辰</p>
          </div>
          <div class="team-card small">
            <h3>校護</h3>
            <p class="name">郭佳蕙</p>
          </div>
          <div class="team-card small">
            <h3>出納</h3>
            <p class="name">詹雅文</p>
          </div>
          <div class="team-card small">
            <h3>會計</h3>
            <p class="name">高毓君</p>
          </div>
          <div class="team-card small">
            <h3>人事</h3>
            <p class="name">林佳蒨</p>
          </div>
          <div class="team-card small">
            <h3>中學部行政</h3>
            <p class="name">王如君</p>
          </div>
          <div class="team-card small">
            <h3>高中部行政</h3>
            <p class="name">謝淳涵</p>
          </div>
        </div>
      </div>

      <!-- 專任老師 -->
      <div class="team-section">
        <h2>專任老師 / 課指組</h2>
        <div class="teachers-grid">
          <div class="team-card">
            <h3>專任教師／課指組組長</h3>
            <p class="name">許丁元</p>
          </div>
          <div class="team-card">
            <h3>專任教師</h3>
            <p class="name">陳淑市</p>
          </div>
          <div class="team-card">
            <h3>專任教師</h3>
            <p class="name">湯翃豪</p>
          </div>
        </div>
      </div>

      <!-- 教師團隊 -->
      <div class="team-section">
        <h2>教師團隊</h2>
        <div class="teachers-grid">
          <div class="team-card">
            <h3>G1 雲杉班</h3>
            <p class="name">羅淑萍</p>
          </div>
          <div class="team-card">
            <h3>G2 月桂班</h3>
            <p class="name">張斯婷</p>
          </div>
          <div class="team-card">
            <h3>G3 星辰班</h3>
            <p class="name">蘇泳貞</p>
          </div>
          <div class="team-card">
            <h3>G4 澄月班</h3>
            <p class="name">鄭景中</p>
          </div>
          <div class="team-card">
            <h3>G5 銀杏班</h3>
            <p class="name">潘怡臻</p>
          </div>
          <div class="team-card">
            <h3>G6 暖陽班</h3>
            <p class="name">林季瑩</p>
          </div>
          <div class="team-card">
            <h3>G7 海洋班</h3>
            <p class="name">陳嘉慧</p>
          </div>
          <div class="team-card">
            <h3>G8 雲彩班</h3>
            <p class="name">余怜瑱</p>
          </div>
          <div class="team-card">
            <h3>G9 茉莉班</h3>
            <p class="name">傅麗如</p>
          </div>
          <div class="team-card">
            <h3>G10 芙蓉班</h3>
            <p class="name">葉友竹</p>
          </div>
          <div class="team-card">
            <h3>G11 榕樹班</h3>
            <p class="name">黃琬茹</p>
          </div>
          <div class="team-card">
            <h3>G12 天使班</h3>
            <p class="name">巫穎妙</p>
          </div>
        </div>
      </div>

    </div>
  </section>

  <footer class="footer">
    <div class="container">
      <p>© 2026 光禾華德福實驗學校. All rights reserved.</p>
    </div>
  </footer>
</Layout>

<style>
  .hero-small { background: linear-gradient(135deg, #8B4513, #228B22); color: white; padding: 4rem 2rem; text-align: center; }
  .hero-small h1 { font-size: 3rem; margin-bottom: 0.5rem; }
  .hero-small p { font-size: 1.2rem; opacity: 0.9; }
  .section { padding: 4rem 2rem; }
  .container { max-width: 1100px; margin: 0 auto; }

  .team-section {
    background: white;
    padding: 2rem;
    border-radius: 20px;
    margin-bottom: 2rem;
    box-shadow: 0 10px 40px rgba(139,69,19,0.1);
  }
  .team-section h2 { 
    color: #8B4513; 
    font-size: 1.5rem; 
    margin-bottom: 1.5rem; 
    text-align: center;
    padding-bottom: 1rem;
    border-bottom: 2px solid #e0d4c8;
  }

  .core-team, .teachers-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
    gap: 1.5rem;
    justify-items: center;
  }

  .team-card {
    text-align: center;
    padding: 1.5rem;
    background: #f9f9f9;
    border-radius: 15px;
    width: 100%;
    max-width: 200px;
  }

  .team-card.small {
    max-width: 140px;
    padding: 1rem;
  }

  .teacher-photo {
    width: 100px;
    height: 100px;
    border-radius: 50%;
    object-fit: cover;
    margin-bottom: 1rem;
    border: 3px solid #228B22;
  }

  .team-card h3 {
    color: #666;
    font-size: 0.85rem;
    margin-bottom: 0.5rem;
    font-weight: normal;
  }

  .team-card .name {
    color: #8B4513;
    font-size: 1rem;
    font-weight: bold;
    margin:0;
  }

  .admin-team {
    text-align: center;
    margin-bottom: 2rem;
  }

  .group-photo {
    max-width: 100%;
    border-radius: 15px;
  }

  .admin-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(120px, 1fr));
    gap: 1rem;
    justify-items: center;
  }

  .footer { background: #333; color: white; padding: 2rem; text-align: center; margin-top: 2rem; }
</style>
