---
import Layout from '../../layouts/Layout.astro';
import Navigation from '../../components/Navigation.astro';
---

<Layout title="家長社群參與年度時程表 | 光禾華德福">
  <Navigation />
  
  <section class="hero-small">
    <div class="container">
      <h1>家長社群參與年度時程表</h1>
      <p>家長參與學校活動的年度規劃</p>
    </div>
  </section>

  <section class="section">
    <div class="container">
      
      <div class="schedule-section">
        <h2>全校性活動</h2>
        <ul>
          <li>年度活動</li>
          <li>三元社群活動</li>
          <li>每日活動</li>
          <li>其他不定期或定期活動</li>
        </ul>
      </div>

      <div class="schedule-section">
        <h2>班級性活動</h2>
        <p>各班級的家長參與活動</p>
      </div>

    </div>
  </section>

  <footer class="footer">
    <div class="container">
      <p>© 2026 光禾華德福實驗學校. All rights reserved.</p>
    </div>
  </footer>
</Layout>

<style>
  .hero-small {
    background: linear-gradient(135deg, #8B4513, #228B22);
    color: white;
    padding: 4rem 2rem;
    text-align: center;
  }

  .hero-small h1 { font-size: 3rem; margin-bottom: 0.5rem; }
  .hero-small p { font-size: 1.2rem; opacity: 0.9; }

  .section { padding: 4rem 2rem; }
  .container { max-width: 800px; margin: 0 auto; }

  .schedule-section {
    background: white;
    padding: 2rem;
    border-radius: 20px;
    margin-bottom: 2rem;
    box-shadow: 0 10px 40px rgba(139,69,19,0.1);
  }

  .schedule-section h2 {
    color: #8B4513;
    font-size: 1.5rem;
    margin-bottom: 1rem;
    border-bottom: 2px solid #FFD700;
    padding-bottom: 0.5rem;
  }

  .schedule-section ul {
    padding-left: 1.5rem;
    color: #666;
  }

  .schedule-section li {
    padding: 0.5rem 0;
  }

  .schedule-section p {
    color: #666;
    line-height: 1.6;
  }

  .footer { background: #333; color: white; padding: 2rem; text-align: center; margin-top: 2rem; }
</style>
