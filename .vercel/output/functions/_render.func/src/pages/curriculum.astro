---
import Layout from '../layouts/Layout.astro';
import Navigation from '../components/Navigation.astro';
---

<Layout title="課程介紹">
  <Navigation />
  
  <section class="hero-small">
    <div class="container">
      <h1>課程介紹</h1>
      <p>十二年一貫的華德福教育</p>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="philosophy-intro">
        <h2>華德福教育特色</h2>
        <p>華德福教育遵循孩子的發展階段，在每個年齡層給予最適合的教育內容。我們重視「頭、心、手」的均衡發展，讓孩子在「做中學」中成長。</p>
      </div>
    </div>
  </section>

  <section class="section curriculum-section">
    <div class="container">
      <div class="curriculum-card elementary">
        <div class="curriculum-header">
          <span class="grade-badge">國小部</span>
          <h2>小學階段（1-6年級）</h2>
        </div>
        <div class="curriculum-content">
          <div class="curriculum-block">
            <h3>🎨 藝術與創造</h3>
            <ul>
              <li>水彩畫、蠟筆畫</li>
              <li>音樂與直笛</li>
              <li>木工、編織</li>
              <li>園藝活動</li>
            </ul>
          </div>
          <div class="curriculum-block">
            <h3>📖 學術基礎</h3>
            <ul>
              <li>主課程模組（中英數）</li>
              <li>本土語言（閩南語、客語）</li>
              <li>自然觀察與科學</li>
              <li>說故事與戲劇</li>
            </ul>
          </div>
          <div class="curriculum-block">
            <h3>🏃 健康與運動</h3>
            <ul>
              <li>優律思美（Eurythmy）</li>
              <li>徒手遊戲</li>
              <li>戶外探索</li>
              <li>季節慶典</li>
            </ul>
          </div>
        </div>
      </div>

      <div class="curriculum-card middle">
        <div class="curriculum-header">
          <span class="grade-badge">國中部</span>
          <h2>中學階段（7-9年級）</h2>
        </div>
        <div class="curriculum-content">
          <div class="curriculum-block">
            <h3>🔬 科學探索</h3>
            <ul>
              <li>物理與化學實驗</li>
              <li>生物與植物學</li>
              <li>地質學初步</li>
              <li>天文學認識</li>
            </ul>
          </div>
          <div class="curriculum-block">
            <h3>🌍 社會與人文</h3>
            <ul>
              <li>歷史與文明</li>
              <li>地理與文化</li>
              <li>哲學思考</li>
              <li>社區服務</li>
            </ul>
          </div>
          <div class="curriculum-block">
            <h3>🛠 技藝實作</h3>
            <ul>
              <li>金木工</li>
              <li>陶藝</li>
              <li>裁縫</li>
              <li>建築初步</li>
            </ul>
          </div>
        </div>
      </div>

      <div class="curriculum-card high">
        <div class="curriculum-header">
          <span class="grade-badge">高中部</span>
          <h2>高中階段（10-12年級）</h2>
        </div>
        <div class="curriculum-content">
          <div class="curriculum-block">
            <h3>📚 學術深化</h3>
            <ul>
              <li>高等數學</li>
              <li>物理、化學、生物</li>
              <li>文學與語言</li>
              <li>藝術史與音樂史</li>
            </ul>
          </div>
          <div class="curriculum-block">
            <h3>💡 專題研究</h3>
            <ul>
              <li>畢業專題</li>
              <li>獨立研究</li>
              <li>社團活動</li>
              <li>領導力培養</li>
            </ul>
          </div>
          <div class="curriculum-block">
            <h3>🌱 生命準備</h3>
            <ul>
              <li>生涯規劃</li>
              <li>志願服務</li>
              <li>環境教育</li>
              <li>世界議題探討</li>
            </ul>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="section features">
    <div class="container">
      <h2 class="section-title">華德福教育的獨特之處</h2>
      <div class="features-grid">
        <div class="feature-card">
          <div class="feature-icon">⏰</div>
          <h3>主課程</h3>
          <p>每天早晨2小時的主課程，讓孩子深入探索單一主題，建立深度學習能力</p>
        </div>
        <div class="feature-card">
          <div class="feature-icon">🎵</div>
          <h3>音樂教育</h3>
          <p>每個年級都學習樂器，從直笛到弦樂，音樂成為生活的一部分</p>
        </div>
        <div class="feature-card">
          <div class="feature-icon">🎭</div>
          <h3>戲劇與藝術</h3>
          <p>透過戲劇展現所學，藝術創作表達內心世界</p>
        </div>
        <div class="feature-card">
          <div class="feature-icon">🌿</div>
          <h3>自然教育</h3>
          <p>在自然中學習，感受季節變化與生命節奏</p>
        </div>
      </div>
    </div>
  </section>

  <footer class="footer">
    <div class="container">
      <p>© 2026 光禾華德福實驗學校. All rights reserved.</p>
    </div>
  </footer>
</Layout>

<style>
  .hero-small {
    background: linear-gradient(135deg, #228B22 0%, #8B4513 100%);
    color: white;
    padding: 4rem 2rem;
    text-align: center;
  }

  .hero-small h1 {
    font-size: 3rem;
    margin-bottom: 0.5rem;
  }

  .section {
    padding: 4rem 2rem;
  }

  .container {
    max-width: 1000px;
    margin: 0 auto;
  }

  .philosophy-intro {
    text-align: center;
    background: linear-gradient(135deg, #fff8dc 0%, #f5deb3 100%);
    padding: 3rem;
    border-radius: 30px;
  }

  .philosophy-intro h2 {
    color: #8B4513;
    font-size: 2rem;
    margin-bottom: 1rem;
  }

  .philosophy-intro p {
    color: #666;
    font-size: 1.1rem;
    line-height: 1.8;
    max-width: 700px;
    margin: 0 auto;
  }

  .curriculum-card {
    background: white;
    border-radius: 30px;
    overflow: hidden;
    margin-bottom: 3rem;
    box-shadow: 0 15px 50px rgba(139, 69, 19, 0.15);
  }

  .curriculum-header {
    padding: 2rem;
    color: white;
    text-align: center;
  }

  .curriculum-card.elementary .curriculum-header {
    background: linear-gradient(135deg, #FF8C00, #FFD700);
  }

  .curriculum-card.middle .curriculum-header {
    background: linear-gradient(135deg, #228B22, #32CD32);
  }

  .curriculum-card.high .curriculum-header {
    background: linear-gradient(135deg, #8B4513, #A0522D);
  }

  .grade-badge {
    display: inline-block;
    background: rgba(255,255,255,0.3);
    padding: 0.3rem 1rem;
    border-radius: 20px;
    font-size: 0.9rem;
    margin-bottom: 0.5rem;
  }

  .curriculum-header h2 {
    margin: 0;
    font-size: 1.8rem;
  }

  .curriculum-content {
    padding: 2rem;
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
    gap: 1.5rem;
  }

  .curriculum-block {
    background: #FFF8DC;
    padding: 1.5rem;
    border-radius: 15px;
  }

  .curriculum-block h3 {
    color: #8B4513;
    font-size: 1.1rem;
    margin-bottom: 1rem;
    padding-bottom: 0.5rem;
    border-bottom: 2px solid #e0d4c8;
  }

  .curriculum-block ul {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .curriculum-block li {
    color: #666;
    padding: 0.4rem 0;
    padding-left: 1.2rem;
    position: relative;
  }

  .curriculum-block li::before {
    content: '✦';
    position: absolute;
    left: 0;
    color: #FF8C00;
    font-size: 0.8rem;
  }

  .section-title {
    text-align: center;
    font-size: 2rem;
    color: #8B4513;
    margin-bottom: 3rem;
  }

  .features {
    background: linear-gradient(135deg, #f5deb3 0%, #fff8dc 100%);
  }

  .features-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
    gap: 1.5rem;
  }

  .feature-card {
    background: white;
    padding: 2rem;
    border-radius: 20px;
    text-align: center;
    box-shadow: 0 10px 30px rgba(139, 69, 19, 0.1);
  }

  .feature-icon {
    font-size: 3rem;
    margin-bottom: 1rem;
  }

  .feature-card h3 {
    color: #8B4513;
    margin-bottom: 0.5rem;
  }

  .feature-card p {
    color: #666;
    margin: 0;
    font-size: 0.95rem;
    line-height: 1.5;
  }

  .footer {
    background: #333;
    color: white;
    padding: 2rem;
    text-align: center;
  }
</style>
