---
import Layout from '../../layouts/Layout.astro';
import Navigation from '../../components/Navigation.astro';
---

<Layout title="影片專區 | 光禾華德福">
  <Navigation />
  
  <section class="hero-small">
    <div class="container">
      <h1>影片專區</h1>
      <p>精彩影片陸續上架中</p>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="video-grid">
        <div class="video-card">
          <div class="video-placeholder">
            <span>🎬</span>
          </div>
          <h3>招生說明會</h3>
          <p>了解光禾華德福教育理念</p>
        </div>

        <div class="video-card">
          <div class="video-placeholder">
            <span>🎬</span>
          </div>
          <h3>課程介紹</h3>
          <p>認識我們的特色課程</p>
        </div>

        <div class="video-card">
          <div class="video-placeholder">
            <span>🎬</span>
          </div>
          <h3>校園環境</h3>
          <p>參觀美麗的校園</p>
        </div>

        <div class="video-card">
          <div class="video-placeholder">
            <span>🎬</span>
          </div>
          <h3>師資介紹</h3>
          <p>認識我們的教師團隊</p>
        </div>

        <div class="video-card">
          <div class="video-placeholder">
            <span>🎬</span>
          </div>
          <h3>活動紀錄</h3>
          <p>精彩活動影片</p>
        </div>

        <div class="video-card">
          <div class="video-placeholder">
            <span>🎬</span>
          </div>
          <h3>學生作品</h3>
          <p>學生創作分享</p>
        </div>
      </div>

      <div class="notice">
        <p>📺 影片正在陸續拍攝與剪輯中，敬請期待！</p>
      </div>
    </div>
  </section>

  <footer class="footer">
    <div class="container">
      <p>© 2026 光禾華德福實驗學校. All rights reserved.</p>
    </div>
  </footer>
</Layout>

<style>
  .hero-small {
    background: linear-gradient(135deg, #228B22, #8B4513);
    color: white;
    padding: 4rem 2rem;
    text-align: center;
  }

  .hero-small h1 { font-size: 3rem; margin-bottom: 0.5rem; }

  .section { padding: 4rem 2rem; }
  .container { max-width: 1000px; margin: 0 auto; }

  .video-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: 1.5rem;
  }

  .video-card {
    background: white;
    border-radius: 20px;
    overflow: hidden;
    box-shadow: 0 10px 40px rgba(139,69,19,0.1);
  }

  .video-placeholder {
    height: 180px;
    background: linear-gradient(135deg, #FFF8DC, #f5deb3);
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .video-placeholder span {
    font-size: 4rem;
  }

  .video-card h3 {
    color: #8B4513;
    padding: 1rem 1rem 0.5rem;
    margin: 0;
  }

  .video-card p {
    color: #666;
    padding: 0 1rem 1rem;
    margin: 0;
    font-size: 0.9rem;
  }

  .notice {
    background: #FFF8DC;
    padding: 1.5rem;
    border-radius: 15px;
    text-align: center;
    margin-top: 2rem;
  }

  .notice p { color: #8B4513; margin: 0; font-weight: 500; }

  .footer { background: #333; color: white; padding: 2rem; text-align: center; }
</style>
